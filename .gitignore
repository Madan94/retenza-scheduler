# Dependencies
frontend/node_modules/
backend/node_modules/
worker/node_modules/
node_modules/

# Environment & secrets (never commit credentials)
.env
.env.*
!.env.example
!.env.*.example

# Build outputs
dist/
dist-ssr/
build/
out/
*.tsbuildinfo

# Prisma (generated clients; schema & migrations stay tracked)
backend/generated/
**/node_modules/.prisma/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Test & coverage
coverage/
.nyc_output/

# Caches
.cache/
.parcel-cache/
.turbo/
.vite/
*.local

# OS
.DS_Store
Thumbs.db
Desktop.ini

# Editors & IDEs
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Docker (local overrides only; keep docker-compose.yml tracked)
docker-compose.override.yml
docker-compose.*.local.yml

# Misc
*.pem
*.key
.vercel
.netlify
